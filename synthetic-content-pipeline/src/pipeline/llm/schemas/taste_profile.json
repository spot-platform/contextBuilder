{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TasteProfile",
  "type": "object",
  "required": ["taste_facets", "recent_obsession", "curiosity_hooks"],
  "additionalProperties": false,
  "properties": {
    "taste_facets": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 30
      }
    },
    "recent_obsession": {
      "type": "string",
      "minLength": 6,
      "maxLength": 80
    },
    "curiosity_hooks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 30
      }
    }
  }
}
