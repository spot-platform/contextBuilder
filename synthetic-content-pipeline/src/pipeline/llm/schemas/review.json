{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpotReview",
  "type": "object",
  "required": [
    "rating",
    "review_text",
    "satisfaction_tags",
    "recommend",
    "will_rejoin",
    "sentiment"
  ],
  "additionalProperties": false,
  "properties": {
    "rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "review_text": {
      "type": "string",
      "minLength": 15,
      "maxLength": 400
    },
    "satisfaction_tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 20
      }
    },
    "recommend": {
      "type": "boolean"
    },
    "will_rejoin": {
      "type": "boolean"
    },
    "sentiment": {
      "type": "string",
      "enum": ["positive", "neutral", "negative"]
    }
  }
}
