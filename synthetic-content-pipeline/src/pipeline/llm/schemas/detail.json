{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpotDetail",
  "type": "object",
  "required": [
    "title",
    "description",
    "activity_purpose",
    "progress_style",
    "materials",
    "target_audience",
    "cost_breakdown",
    "host_intro",
    "policy_notes"
  ],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 12,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "minLength": 80,
      "maxLength": 800
    },
    "activity_purpose": {
      "type": "string",
      "minLength": 20,
      "maxLength": 200
    },
    "progress_style": {
      "type": "string",
      "minLength": 20,
      "maxLength": 300
    },
    "materials": {
      "type": "array",
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 40
      }
    },
    "target_audience": {
      "type": "string",
      "minLength": 10,
      "maxLength": 120
    },
    "cost_breakdown": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["item", "amount"],
        "additionalProperties": false,
        "properties": {
          "item": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          },
          "amount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 500000
          }
        }
      }
    },
    "host_intro": {
      "type": "string",
      "minLength": 30,
      "maxLength": 300
    },
    "policy_notes": {
      "type": ["string", "null"],
      "maxLength": 200
    }
  }
}
