{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CriticEvaluation",
  "type": "object",
  "required": [
    "naturalness_score",
    "consistency_score",
    "regional_fit_score",
    "persona_fit_score",
    "safety_score",
    "peer_tone_score",
    "reject",
    "reasons"
  ],
  "additionalProperties": false,
  "properties": {
    "naturalness_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "consistency_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "regional_fit_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "persona_fit_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "safety_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "peer_tone_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reject": {
      "type": "boolean"
    },
    "reasons": {
      "type": "array",
      "minItems": 0,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      }
    }
  }
}
