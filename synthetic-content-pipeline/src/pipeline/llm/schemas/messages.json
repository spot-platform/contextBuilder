{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpotCommunicationSnippets",
  "type": "object",
  "required": [
    "recruiting_intro",
    "join_approval",
    "day_of_notice",
    "post_thanks"
  ],
  "additionalProperties": false,
  "properties": {
    "recruiting_intro": {
      "type": "string",
      "minLength": 40,
      "maxLength": 200
    },
    "join_approval": {
      "type": "string",
      "minLength": 20,
      "maxLength": 150
    },
    "day_of_notice": {
      "type": "string",
      "minLength": 30,
      "maxLength": 200
    },
    "post_thanks": {
      "type": "string",
      "minLength": 20,
      "maxLength": 150
    }
  }
}
