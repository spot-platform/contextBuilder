{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpotPlan",
  "type": "object",
  "required": ["steps", "total_duration_minutes"],
  "additionalProperties": false,
  "properties": {
    "steps": {
      "type": "array",
      "minItems": 3,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["time", "activity"],
        "additionalProperties": false,
        "properties": {
          "time": {
            "type": "string",
            "pattern": "^(?:[0-2][0-9]:[0-5][0-9]|\\+[0-9]{1,3}분)$"
          },
          "activity": {
            "type": "string",
            "minLength": 4,
            "maxLength": 40
          }
        }
      }
    },
    "total_duration_minutes": {
      "type": "integer",
      "minimum": 60,
      "maximum": 360
    }
  }
}
