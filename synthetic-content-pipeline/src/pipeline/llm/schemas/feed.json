{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeedPreview",
  "type": "object",
  "required": [
    "title",
    "summary",
    "tags",
    "price_label",
    "region_label",
    "time_label",
    "status",
    "supporter_label"
  ],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 12,
      "maxLength": 40
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 400
    },
    "tags": {
      "type": "array",
      "minItems": 2,
      "maxItems": 6,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 20
      }
    },
    "price_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "region_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "time_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "status": {
      "type": "string",
      "enum": ["recruiting", "closed", "in_progress"]
    },
    "supporter_label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    }
  }
}
